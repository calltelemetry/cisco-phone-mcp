{
  "name": "@calltelemetry/cisco-phone-mcp",
  "version": "0.2.0",
  "description": "MCP server for direct Cisco IP phone control and monitoring via built-in HTTP endpoints",
  "type": "module",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli.ts",
    "test": "tsx --test test/*.test.ts",
    "test:coverage": "c8 --reporter=lcov --reporter=text tsx --test test/*.test.ts",
    "prepack": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "cisco",
    "phone",
    "voip",
    "rtp",
    "cucm",
    "ip-phone",
    "call-quality"
  ],
  "author": "CallTelemetry",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "fast-xml-parser": "^4.5.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "c8": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.12.0"
}
